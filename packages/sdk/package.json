{
  "name": "@trstlyr/sdk",
  "version": "0.1.0",
  "description": "Lightweight SDK for querying trust scores and posting behavioral attestations to the TrstLyr API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "types": "./dist/middleware.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "trust",
    "ai-agents",
    "attestation",
    "behavioral",
    "eas",
    "base"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tankcdr/aegis.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/tankcdr/aegis/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/tankcdr/aegis/issues"
  }
}
